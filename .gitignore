# ─── Build directories (CMake working dirs, fully ignored) ─────────────────
SparkyLoader/build/
SparkyLoader/build-win/
SparkyLoader/build-*/

# ─── Binary output (top-level bin/ is tracked) ─────────────────────────────
# SparkyLoader/bin/ is intentionally NOT ignored so compiled binaries are kept

# ─── CMake generated files ─────────────────────────────────────────────────
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CPackConfig.cmake
CPackSourceConfig.cmake
_deps/
*.cmake
!SparkyLoader/toolchain-windows-mingw.cmake
!SparkyLoader/CMakeLists.txt

# ─── Compiler / linker intermediates ───────────────────────────────────────
*.o
*.obj
*.a
*.lib
*.pdb
*.ilk
*.exp
*.map
*.d

# ─── OS / editor noise ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.user
.vs/
.vscode/settings.json
.idea/

# ─── Logs produced at runtime ──────────────────────────────────────────────
*.log
