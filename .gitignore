# ─── Build directories (CMake working dirs, fully ignored) ─────────────────
SparkyLoader/build/
SparkyLoader/build-win/
SparkyLoader/build-*/
SparkyLoader/user/build/

# ─── Binary output (compiled files are not committed — use CI artifacts) ────
SparkyLoader/user/bin/*.exe
SparkyLoader/user/bin/*.dll
SparkyLoader/user/bin/*.pdb
# keep .gitkeep so the directory exists in the repo
!SparkyLoader/user/bin/.gitkeep

# ─── CMake generated files ─────────────────────────────────────────────────
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CPackConfig.cmake
CPackSourceConfig.cmake
_deps/
*.cmake
!SparkyLoader/user/CMakeLists.txt
!SparkyLoader/toolchain-windows-mingw.cmake
!SparkyLoader/CMakeLists.txt

# ─── Compiler / linker intermediates ───────────────────────────────────────
*.o
*.obj
*.a
*.lib
*.pdb
*.ilk
*.exp
*.map
*.d

# ─── OS / editor noise ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.user
.vs/
.vscode/settings.json
.idea/

# ─── Logs produced at runtime ──────────────────────────────────────────────
*.log

# ─── Secrets & credentials (NEVER commit these) ────────────────────────────
.env
*.env
SparkyServer/sparky.crt
SparkyServer/sparky.key
SparkyServer/sparky.connstr
sparky-cert.pem
sparky-private.key

# ─── Database backup dumps ───────────────────────────────────────────────────
SparkyServer/backups/
